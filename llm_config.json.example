{
  "openai_api_key": "your-openai-api-key-here",
  "anthropic_api_key": "your-anthropic-api-key-here",
  "default_provider": "openai",
  "default_model": "gpt-4",
  "openai_models": [
    "gpt-4",
    "gpt-4-turbo-preview",
    "gpt-3.5-turbo"
  ],
  "anthropic_models": [
    "claude-3-opus-20240229",
    "claude-3-sonnet-20240229",
    "claude-3-haiku-20240307"
  ],
  "temperature": 0.3,
  "max_retries": 3,
  "timeout_seconds": 30
}

